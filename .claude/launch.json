{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel (artisan serve)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--host=127.0.0.1", "--port=8000"],
      "port": 8000
    },
    {
      "name": "Vite (npm dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
